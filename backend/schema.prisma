// AdiaraAcademy — Schéma Prisma
// Base de données : PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  ELEVE
  PROFESSEUR
  ADMIN
}

enum NiveauScolaire {
  COLLEGE
  LYCEE
  UNIVERSITE
}

enum Matiere {
  MATHEMATIQUES
  PHYSIQUE
  CHIMIE
  SCIENCES_VIE_TERRE
  INFORMATIQUE
}

enum StatutProgression {
  NON_COMMENCE
  EN_COURS
  TERMINE
}

enum TypeQuiz {
  QCM
  REPONSE_LIBRE
  VRAI_FAUX
}

enum Difficulte {
  FACILE
  MOYEN
  DIFFICILE
}

// ─────────────────────────────────────────
// UTILISATEUR
// ─────────────────────────────────────────

model Utilisateur {
  id              String         @id @default(uuid())
  nom             String
  prenom          String
  email           String         @unique
  motDePasse      String
  role            Role           @default(ELEVE)
  niveau          NiveauScolaire
  classe          String?        // ex: "Terminale S", "L2 Maths"
  ecole           String?
  xpTotal         Int            @default(0)
  streak          Int            @default(0)
  derniereActivite DateTime?
  creeLe          DateTime       @default(now())
  misAJourLe      DateTime       @updatedAt

  // Relations
  coursCreees     Cours[]
  progressions    Progression[]
  tentatives      Tentative[]
  badges          BadgeUtilisateur[]

  @@map("utilisateurs")
}

// ─────────────────────────────────────────
// COURS & CHAPITRES
// ─────────────────────────────────────────

model Cours {
  id          String         @id @default(uuid())
  titre       String
  description String
  matiere     Matiere
  niveau      NiveauScolaire
  classe      String?        // ex: "Terminale S", "Licence 1"
  imageUrl    String?
  publie      Boolean        @default(false)
  creeLe      DateTime       @default(now())
  misAJourLe  DateTime       @updatedAt

  // Relations
  auteurId    String
  auteur      Utilisateur    @relation(fields: [auteurId], references: [id])
  chapitres   Chapitre[]

  @@map("cours")
}

model Chapitre {
  id         String   @id @default(uuid())
  titre      String
  // Contenu en Markdown avec LaTeX — rendu par KaTeX côté client
  // Exemple : "Soit $f(x) = x^2$, alors $f'(x) = 2x$"
  contenu    String   @db.Text
  ordre      Int
  xpObtenu   Int      @default(10)
  creeLe     DateTime @default(now())
  misAJourLe DateTime @updatedAt

  // Relations
  coursId    String
  cours      Cours        @relation(fields: [coursId], references: [id], onDelete: Cascade)
  quiz       Quiz[]
  progressions Progression[]

  @@unique([coursId, ordre])
  @@map("chapitres")
}

// ─────────────────────────────────────────
// QUIZ & QUESTIONS
// ─────────────────────────────────────────

model Quiz {
  id         String   @id @default(uuid())
  titre      String
  type       TypeQuiz @default(QCM)
  dureMin    Int?     // durée en minutes (null = pas de limite)
  xpMax      Int      @default(50)
  creeLe     DateTime @default(now())
  misAJourLe DateTime @updatedAt

  // Relations
  chapitreId String
  chapitre   Chapitre   @relation(fields: [chapitreId], references: [id], onDelete: Cascade)
  questions  Question[]
  tentatives Tentative[]

  @@map("quiz")
}

model Question {
  id              String     @id @default(uuid())
  enonce          String     @db.Text  // supporte LaTeX : "$\\frac{a}{b}$"
  // Pour QCM : ["A) 2", "B) 4", "C) -1", "D) 0"]
  // Pour Vrai/Faux : ["Vrai", "Faux"]
  // Pour réponse libre : null
  options         Json?
  reponseCorrecte String     @db.Text
  explication     String?    @db.Text  // correction détaillée
  difficulte      Difficulte @default(MOYEN)
  ordre           Int

  // Relations
  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, ordre])
  @@map("questions")
}

// ─────────────────────────────────────────
// PROGRESSION & TENTATIVES
// ─────────────────────────────────────────

model Progression {
  id           String             @id @default(uuid())
  statut       StatutProgression  @default(NON_COMMENCE)
  score        Int?               // 0–100
  xpGagne      Int                @default(0)
  tentatives   Int                @default(0)
  termineLeAt  DateTime?
  creeLe       DateTime           @default(now())
  misAJourLe   DateTime           @updatedAt

  // Relations
  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])
  chapitreId    String
  chapitre      Chapitre    @relation(fields: [chapitreId], references: [id])

  @@unique([utilisateurId, chapitreId])
  @@map("progressions")
}

model Tentative {
  id          String   @id @default(uuid())
  // Réponses stockées en JSON : { "question_id": "réponse_donnée", ... }
  reponses    Json
  score       Int      // 0–100
  xpGagne     Int      @default(0)
  dureeSec    Int?     // durée réelle en secondes
  commenceLe  DateTime @default(now())
  termineLeAt DateTime?

  // Relations
  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])
  quizId        String
  quiz          Quiz        @relation(fields: [quizId], references: [id])

  @@map("tentatives")
}

// ─────────────────────────────────────────
// BADGES & GAMIFICATION
// ─────────────────────────────────────────

model Badge {
  id          String   @id @default(uuid())
  nom         String   @unique
  description String
  icone       String   // emoji ou URL image
  // Exemple de condition : { "type": "streak", "valeur": 7 }
  // Autres types : "xp_total", "cours_termine", "quiz_parfait"
  condition   Json
  creeLe      DateTime @default(now())

  // Relations
  utilisateurs BadgeUtilisateur[]

  @@map("badges")
}

model BadgeUtilisateur {
  id        String   @id @default(uuid())
  obtenuLe  DateTime @default(now())

  // Relations
  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])
  badgeId       String
  badge         Badge       @relation(fields: [badgeId], references: [id])

  @@unique([utilisateurId, badgeId])
  @@map("badges_utilisateurs")
}
